# Machine-dependent paths. Copy this file to `env.yaml` (git-ignored) and edit the
# values for THIS machine. All four keys are required. `~`, `$VAR` and `${VAR}` are
# expanded (os.path.expanduser / expandvars). Loaded by envconfig.py.

# The ghost_dataset directory on THIS machine. Differs per server (dragon, tiger, ...).
# Point it at the dir that contains the named scenes (36build/, 22build/, ...).
data_root: /path/to/ghost_dataset

# Where training outputs (checkpoints, logs, result json/png) are collected.
# This is the SHARED NFS directory and should be the SAME on every machine.
output_root: /srv/shared/yoshida

# Local fast-disk scratch for regenerable representation caches (uint16 voxel caches,
# eventnet caches). Keep this on a LOCAL disk (not NFS) — training reads it heavily.
cache_root: /local/scratch/$USER/fwc_cache

# The read-only Ghost-FWL / FWL-ToPM repo on THIS machine. Provides the PYTHONPATH
# (its src/) and the frozen ToPM checkpoints referenced by downstream/configs/*.yaml.
topm_repo_root: /path/to/fwl_mae/neurips2026
